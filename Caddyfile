:8080 {
    root * /usr/share/caddy

    encode gzip zstd

    # route forces declaration order so @forbidden runs BEFORE try_files.
    # Without route, Caddy auto-orders `respond` after `try_files`, which
    # means try_files =404 fires first and the forbidden check never runs.
    route {
        # Block access to sensitive paths
        @forbidden {
            path /.git/* /node_modules/* /vendor/* /.venv/*
        }
        respond @forbidden 404

        # 1) Try to serve a real file: the path as-is, then with a .html suffix,
        #    then as a directory index. If nothing matches, emit a real 404
        #    so handle_errors can decide what to do with it.
        try_files {path} {path}.html {path}/index.html =404

        file_server
    }

    handle_errors 404 {
        # 2) Requests with a non-HTML extension are assets. They must never
        #    fall back to index.html — return a real 404 instead.
        @asset {
            path_regexp \.[A-Za-z0-9]+$
            not path *.html *.htm
        }
        handle @asset {
            respond "Not Found" 404
        }

        # 3) Document-like requests:
        #    - If /404.html exists in the site root, treat the site as an MPA
        #      and serve it with a real 404 status.
        #    - Otherwise, treat it as a SPA and serve /index.html with 200
        #      so the client-side router can render the route.
        @hasMpa404 file /404.html
        handle @hasMpa404 {
            rewrite * /404.html
            file_server {
                status 404
            }
        }

        handle {
            rewrite * /index.html
            file_server {
                status 200
            }
        }
    }

    zeaburextension

    log {
        output stderr
    }
}
